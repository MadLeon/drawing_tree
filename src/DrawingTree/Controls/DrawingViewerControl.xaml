<UserControl x:Class="DrawingTree.Controls.DrawingViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:DrawingTree.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>

        <Geometry x:Key="HouseGeo">M200-160v-366L88-440l-48-64 440-336 160 122v-82h120v174l160 122-48 64-112-86v366H520v-240h-80v240H200Zm80-80h80v-240h240v240h80v-347L480-739 280-587v347Zm120-319h160q0-32-24-52.5T480-632q-32 0-56 20.5T400-559Zm-40 319v-240h240v240-240H360v240Z</Geometry>
        <Geometry x:Key="PrintGeo">M640-640v-120H320v120h-80v-200h480v200h-80Zm-480 80h640-640Zm560 100q17 0 28.5-11.5T760-500q0-17-11.5-28.5T720-540q-17 0-28.5 11.5T680-500q0 17 11.5 28.5T720-460Zm-80 260v-160H320v160h320Zm80 80H240v-160H80v-240q0-51 35-85.5t85-34.5h560q51 0 85.5 34.5T880-520v240H720v160Zm80-240v-160q0-17-11.5-28.5T760-560H200q-17 0-28.5 11.5T160-520v160h80v-80h480v80h80Z</Geometry>
        <Geometry x:Key="AddBoxGeo">M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160ZM200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h560q33 0 56.5 23.5T840-760v560q0 33-23.5 56.5T760-120H200Zm0-80h560v-560H200v560Zm0-560v560-560Z</Geometry>
        <Geometry x:Key="IndeterminateCheckBoxGeo">M280-440h400v-80H280v80Zm-80 320q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h560q33 0 56.5 23.5T840-760v560q0 33-23.5 56.5T760-120H200Zm0-80h560v-560H200v560Zm0-560v560-560Z</Geometry>
        <Geometry x:Key="OpenInNewGeo">M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h280v80H200v560h560v-280h80v280q0 33-23.5 56.5T760-120H200Zm188-212-56-56 372-372H560v-80h280v280h-80v-144L388-332Z</Geometry>

        <!-- Y-flipped style for icons that need it (expand/collapse icons) -->
        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleY="-1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBd" Background="Transparent" CornerRadius="2" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBd" Property="Background" Value="#15000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar: title left, buttons right -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                Background="#F0F0F0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ViewerTitleLabel" Grid.Column="0"
                           FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Foreground="#333"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- House icon: Stretch=Uniform only, no ScaleY flip -->
                    <Button Style="{StaticResource IconBtn}" Width="32" Height="32"
                            Margin="0,0,8,0" ToolTip="Return to home"
                            Click="HomeButton_Click">
                        <Path Data="{StaticResource HouseGeo}"
                              Stretch="Uniform"
                              Fill="#333333" Width="20" Height="20"/>
                    </Button>
                    <!-- Print icon: same -->
                    <Button Style="{StaticResource IconBtn}" Width="32" Height="32"
                            ToolTip="Print current drawing"
                            Click="PrintButton_Click">
                        <Path Data="{StaticResource PrintGeo}"
                              Stretch="Uniform"
                              Fill="#333333" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Tree | Splitter | PDF | Splitter | Info -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: readonly drawing tree ──────────────────────── -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Padding="10,6" Background="#F0F0F0">
                        <TextBlock Text="Drawing Tree" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <ScrollViewer x:Name="ViewerTreeScrollViewer" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="White">
                        <TreeView x:Name="ViewerTreeView"
                                  Background="Transparent" BorderThickness="0" Padding="8"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ViewerTreeView_PreviewMouseWheel">

                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:DrawingNode}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <!--
                                            Visibility="Collapsed" (not Hidden) so leaf nodes take no space
                                            and the connector H-line reaches directly to the node border.
                                        -->
                                        <Button x:Name="ExpandBtn"
                                                Style="{StaticResource IconBtn}"
                                                Width="20" Height="20" Margin="0,0,2,0"
                                                Visibility="Collapsed"
                                                Click="ExpandButton_Click">
                                            <Path x:Name="ExpandIcon"
                                                  Data="{StaticResource IndeterminateCheckBoxGeo}"
                                                  Style="{StaticResource IconPath}"
                                                  Fill="#E53935" Width="13" Height="13"/>
                                        </Button>
                                        <Border x:Name="NodeBorder"
                                                BorderThickness="1" BorderBrush="#E0E0E0"
                                                Background="White" CornerRadius="2"
                                                Padding="6,4" Margin="0,2"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="ViewerNodeBorder_MouseLeftButtonUp">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Drawing.DrawingNumber}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                                <Button Style="{StaticResource IconBtn}"
                                                        Width="20" Height="20" ToolTip="Open PDF"
                                                        Click="ViewerOpenPdfButton_Click">
                                                    <Path Data="{StaticResource OpenInNewGeo}"
                                                          Stretch="Uniform"
                                                          Fill="#1976D2" Width="13" Height="13"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                            <Setter TargetName="ExpandBtn" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                            <Setter TargetName="ExpandIcon" Property="Data" Value="{StaticResource AddBoxGeo}"/>
                                            <Setter TargetName="ExpandIcon" Property="Fill" Value="#388E3C"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="NodeBorder" Property="Background" Value="#E3F2FD"/>
                                            <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#1976D2"/>
                                        </DataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>

                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Column="0" Grid.Row="0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Rectangle x:Name="VLineUpper" Grid.Row="0"
                                                                   Fill="Black" Width="1" HorizontalAlignment="Center"
                                                                   Visibility="Hidden"/>
                                                        <Rectangle x:Name="VLineLowerHead" Grid.Row="1"
                                                                   Fill="Black" Width="1" HorizontalAlignment="Center"
                                                                   Visibility="Hidden"/>
                                                        <Rectangle x:Name="HLine" Grid.RowSpan="2"
                                                                   Fill="Black" Height="1" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right" Width="10"
                                                                   Visibility="Hidden"/>
                                                    </Grid>

                                                    <ContentPresenter Grid.Column="1" Grid.Row="0"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"/>

                                                    <Rectangle x:Name="VLineChildren"
                                                               Grid.Column="0" Grid.Row="1"
                                                               Fill="Black" Width="1" HorizontalAlignment="Center"
                                                               Visibility="Hidden"/>

                                                    <Border x:Name="ChildrenArea"
                                                            Grid.Column="1" Grid.Row="1"
                                                            Visibility="Collapsed">
                                                        <ItemsPresenter x:Name="ItemsHost"/>
                                                    </Border>
                                                </Grid>

                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsRootNode}" Value="False">
                                                        <Setter TargetName="VLineUpper" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="HLine" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsRootNode}" Value="False"/>
                                                            <Condition Binding="{Binding IsLastChild}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="VLineLowerHead" Property="Visibility" Value="Visible"/>
                                                        <Setter TargetName="VLineChildren" Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter TargetName="ChildrenArea" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <!-- Keep vertical line when expanded and not last child -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                                            <Condition Binding="{Binding IsLastChild}" Value="False"/>
                                                            <Condition Binding="{Binding IsRootNode}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="VLineChildren" Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- ── Center: PDF viewer ────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                        Padding="10,6" Background="#F0F0F0">
                    <TextBlock Text="PDF Viewer" FontWeight="Bold" FontSize="13"/>
                </Border>
                <!--
                    PDF pages sit in a StackPanel with LayoutTransform so zoom via ScaleTransform
                    is instant (GPU only, no re-render). ScrollViewer sees the scaled layout size.
                -->
                <ScrollViewer x:Name="PdfScrollViewer" Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#666666"
                              PreviewMouseWheel="PdfScrollViewer_PreviewMouseWheel"
                              PreviewMouseLeftButtonDown="PdfScrollViewer_PreviewMouseLeftButtonDown"
                              PreviewMouseLeftButtonUp="PdfScrollViewer_PreviewMouseLeftButtonUp"
                              PreviewMouseMove="PdfScrollViewer_PreviewMouseMove">
                    <StackPanel x:Name="PdfPagesPanel" Orientation="Vertical"
                                Margin="16" HorizontalAlignment="Center">
                        <StackPanel.LayoutTransform>
                            <ScaleTransform x:Name="PdfZoomTransform" ScaleX="1" ScaleY="1"/>
                        </StackPanel.LayoutTransform>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- ── Right: readonly info panel ───────────────────────── -->
            <Border Grid.Column="4" Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Padding="10,6" Background="#F0F0F0">
                        <TextBlock Text="Drawing Info" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel x:Name="InfoPanel" IsEnabled="False">

                            <TextBlock Text="Drawing Number" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoDrawingNumber" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"/>

                            <TextBlock Text="Revision" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoRevision" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"/>

                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoDescription" IsReadOnly="True"
                                     Background="#F5F5F5" Height="60" Padding="5,4"
                                     FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Quantity In Assembly" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoQuantity" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Is Assembly" FontWeight="SemiBold" FontSize="11"
                                           Foreground="#666" VerticalAlignment="Center"/>
                                <CheckBox x:Name="InfoIsAssembly"
                                          Margin="8,0,0,0" VerticalAlignment="Center"
                                          IsEnabled="False"/>
                            </StackPanel>

                            <TextBlock Text="File Path" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoFilePath" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="11" Margin="0,0,0,10"
                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
