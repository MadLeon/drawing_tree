<UserControl x:Class="DrawingTree.Controls.TreeBuilderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:DrawingTree.Models"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>

        <!-- ── Material Icons path geometries (viewBox 0 -960 960 960, Y-flipped via RenderTransform) ── -->
        <Geometry x:Key="OpenInNewGeo">M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h280v80H200v560h560v-280h80v280q0 33-23.5 56.5T760-120H200Zm188-212-56-56 372-372H560v-80h280v280h-80v-144L388-332Z</Geometry>
        <Geometry x:Key="AddCircleGeo">M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z</Geometry>
<Geometry x:Key="DoNotDisturbOnGeo">M280-440h400v-80H280v80ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z</Geometry>

        <!-- Path style: apply Y-flip transform so Material Icons render correctly in WPF -->
        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleY="-1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transparent icon button with subtle hover -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBd" Background="Transparent" CornerRadius="2" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBd" Property="Background" Value="#15000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="White" PreviewDragOver="RootGrid_PreviewDragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                Background="#F0F0F0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PoLabel" Grid.Column="0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Save" Width="80" Height="32" Margin="0,0,10,0" Click="SaveButton_Click"/>
                    <Button Content="Return" Width="80" Height="32" Click="ReturnButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Left | Splitter | Tree | Splitter | Info -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel ──────────────────────────────────────── -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Padding="10,6" Background="#F0F0F0">
                        <Grid>
                            <TextBlock Text="Drawings" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource IconBtn}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="22" Height="22" ToolTip="Add drawing"
                                    Click="AddDrawingButton_Click">
                                <Path Data="{StaticResource AddCircleGeo}"
                                      Style="{StaticResource IconPath}"
                                      Fill="#388E3C" Width="15" Height="15"/>
                            </Button>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DrawingListPanel" Padding="4"
                                      PreviewMouseLeftButtonDown="LeftPanel_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="LeftPanel_PreviewMouseMove">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="LeftItemBorder"
                                            Padding="6,4" Margin="2,2"
                                            Background="White" BorderBrush="#E0E0E0"
                                            BorderThickness="1" CornerRadius="2"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="LeftItemBorder_MouseLeftButtonUp">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DrawingNumber}" FontSize="12"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <Button Style="{StaticResource IconBtn}" Width="20" Height="20"
                                                    ToolTip="Open PDF" Click="LeftOpenPdfButton_Click">
                                                <Path Data="{StaticResource OpenInNewGeo}"
                                                      Stretch="Uniform"
                                                      Fill="#1976D2" Width="13" Height="13"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                            <Setter TargetName="LeftItemBorder" Property="Opacity" Value="0.25"/>
                                            <Setter TargetName="LeftItemBorder" Property="Background" Value="#F0F0F0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="LeftItemBorder" Property="Background" Value="#E3F2FD"/>
                                            <Setter TargetName="LeftItemBorder" Property="BorderBrush" Value="#1976D2"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- ── Tree panel ───────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                        Padding="10,6" Background="#F0F0F0">
                    <TextBlock Text="Drawing Tree" FontWeight="Bold" FontSize="13"/>
                </Border>
                <ScrollViewer x:Name="TreeScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto" Background="White">
                    <TreeView x:Name="DrawingTreeView"
                              Background="Transparent" BorderThickness="0" Padding="8"
                              AllowDrop="True"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              DragOver="TreeView_DragOver"
                              DragLeave="TreeView_DragLeave"
                              Drop="TreeView_Drop"
                              PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="TreeView_PreviewMouseMove"
                              PreviewMouseWheel="TreeView_PreviewMouseWheel">

                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:DrawingNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel x:Name="RootStack">
                                    <!-- Job/Line header: visible only for root assembly nodes (HasJobInfo=True) -->
                                    <StackPanel x:Name="JobInfoStack" Visibility="Collapsed" Margin="2,4,0,4">
                                        <TextBlock Text="{Binding JobHeader}"
                                                   FontWeight="Bold" FontSize="13" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding LineHeader}"
                                                   FontSize="12" Foreground="#555555"/>
                                    </StackPanel>
                                    <Border x:Name="NodeBorder"
                                            BorderThickness="1" BorderBrush="#E0E0E0"
                                            Background="White" CornerRadius="2"
                                            Padding="6,4" Margin="0,2"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="TreeNodeBorder_MouseLeftButtonUp">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Drawing.DrawingNumber}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <Button Style="{StaticResource IconBtn}"
                                                    Width="20" Height="20" ToolTip="Open PDF"
                                                    Click="TreeOpenPdfButton_Click">
                                                <Path Data="{StaticResource OpenInNewGeo}"
                                                      Stretch="Uniform"
                                                      Fill="#1976D2" Width="13" Height="13"/>
                                            </Button>
                                            <Button x:Name="RemoveBtn"
                                                    Style="{StaticResource IconBtn}"
                                                    Width="20" Height="20" ToolTip="Remove from tree"
                                                    Margin="2,0,0,0"
                                                    Click="RemoveFromTree_Click">
                                                <Path Data="{StaticResource DoNotDisturbOnGeo}"
                                                      Style="{StaticResource IconPath}"
                                                      Fill="#E53935" Width="13" Height="13"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <!-- Root assembly nodes: show job/line header, hide remove button, add top gap -->
                                    <DataTrigger Binding="{Binding HasJobInfo}" Value="True">
                                        <Setter TargetName="JobInfoStack" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="RemoveBtn" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="RootStack" Property="Margin" Value="0,16,0,0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                        <Setter TargetName="NodeBorder" Property="Opacity" Value="0.25"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="NodeBorder" Property="Background" Value="#E3F2FD"/>
                                        <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#1976D2"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                        <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#2196F3"/>
                                        <Setter TargetName="NodeBorder" Property="Background" Value="#E3F2FD"/>
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <!--
                                                2-col × 2-row Grid ensures connector column heights
                                                automatically match content column heights:
                                                  Row0 (Auto) = NodeBorder height  → VLineUpper/VLineLowerHead/HLine
                                                  Row1 (Auto) = ChildrenArea height → VLineChildren fills it
                                            -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Connector header: upper/lower halves + horizontal arm -->
                                                <Grid Grid.Column="0" Grid.Row="0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Rectangle x:Name="VLineUpper" Grid.Row="0"
                                                               Fill="Black" Width="1" HorizontalAlignment="Center"
                                                               Visibility="Hidden"/>
                                                    <Rectangle x:Name="VLineLowerHead" Grid.Row="1"
                                                               Fill="Black" Width="1" HorizontalAlignment="Center"
                                                               Visibility="Hidden"/>
                                                    <Rectangle x:Name="HLine" Grid.RowSpan="2"
                                                               Fill="Black" Height="1" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" Width="10"
                                                               Visibility="Hidden"/>
                                                </Grid>

                                                <!-- Node content (header) -->
                                                <ContentPresenter Grid.Column="1" Grid.Row="0"
                                                                  ContentSource="Header"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"/>

                                                <!-- Connector children: vertical line through subtree -->
                                                <Rectangle x:Name="VLineChildren"
                                                           Grid.Column="0" Grid.Row="1"
                                                           Fill="Black" Width="1" HorizontalAlignment="Center"
                                                           Visibility="Hidden"/>

                                                <!-- Children area -->
                                                <Border x:Name="ChildrenArea"
                                                        Grid.Column="1" Grid.Row="1"
                                                        Visibility="Collapsed">
                                                    <ItemsPresenter x:Name="ItemsHost"/>
                                                </Border>
                                            </Grid>

                                            <ControlTemplate.Triggers>
                                                <!-- Non-root: show upper connector and horizontal arm -->
                                                <DataTrigger Binding="{Binding IsRootNode}" Value="False">
                                                    <Setter TargetName="VLineUpper" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="HLine" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <!-- Non-root AND non-last: extend line down through subtree -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsRootNode}" Value="False"/>
                                                        <Condition Binding="{Binding IsLastChild}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="VLineLowerHead" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="VLineChildren" Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                                <!-- Show children area when node has children -->
                                                <DataTrigger Binding="{Binding HasChildren}" Value="True">
                                                    <Setter TargetName="ChildrenArea" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- ── Info panel ───────────────────────────────────────── -->
            <Border Grid.Column="4" Background="#FAFAFA">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Padding="10,6" Background="#F0F0F0">
                        <TextBlock Text="Drawing Info" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel x:Name="InfoPanel" IsEnabled="False">

                            <TextBlock Text="Drawing Number" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoDrawingNumber" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"/>

                            <TextBlock Text="Revision" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoRevision" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"
                                     TextChanged="InfoRevision_TextChanged"/>

                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoDescription" Height="60" Padding="5,4"
                                     FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,10"
                                     TextChanged="InfoDescription_TextChanged"/>

                            <TextBlock Text="Quantity In Assembly" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoQuantity" Height="28" Padding="5,4"
                                     FontSize="12" Margin="0,0,0,10"
                                     TextChanged="InfoQuantity_TextChanged"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Is Assembly" FontWeight="SemiBold" FontSize="11"
                                           Foreground="#666" VerticalAlignment="Center"/>
                                <CheckBox x:Name="InfoIsAssembly"
                                          Margin="8,0,0,0" VerticalAlignment="Center"
                                          Checked="InfoIsAssembly_Changed"
                                          Unchecked="InfoIsAssembly_Changed"/>
                            </StackPanel>

                            <TextBlock Text="File Path" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666" Margin="0,0,0,3"/>
                            <TextBox x:Name="InfoFilePath" IsReadOnly="True"
                                     Background="#F5F5F5" Height="28" Padding="5,4"
                                     FontSize="11" Margin="0,0,0,10"
                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
